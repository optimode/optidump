[Unit]
Description=OptidDump MySQL backup (%i)
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/optidump --config /etc/optidump/config.yml --section %i

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=optidump-%i

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadWritePaths=/opt/backup

[Install]
WantedBy=multi-user.target
